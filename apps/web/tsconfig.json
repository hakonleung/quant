{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "verbatimModuleSyntax": false,
    "paths": {
      "@quant/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@quant/terminal": [
        "../../packages/terminal/src/index.ts"
      ]
    },
    "allowJs": true
  },
  "include": [
    "app/**/*",
    "lib/**/*",
    "components/**/*",
    "__tests__/**/*",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist"
  ]
}
