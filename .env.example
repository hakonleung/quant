# Copy to .env (gitignored). Never commit real keys.

# ---- LLM (see docs/integrations/llm-providers.md) ----
# Provider selection follows the hardcoded catalog order in
# services/py/quant_io/llm/providers.py — first row with an API key
# present in env wins. Set whichever key(s) you want available.
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=

# ---- IPC (see docs/integrations/ipc-py-ts.md) ----
# Python Flight server bind port; NestJS dials QUANT_FLIGHT_TARGET=host:port.
QUANT_FLIGHT_PORT=8815
QUANT_FLIGHT_TARGET=127.0.0.1:8815

# ---- API server (NestJS) ----
API_HOST=127.0.0.1
API_PORT=3001

# ---- Logging ----
QUANT_LOG_LEVEL=INFO

# ---- Notifications (see docs/modules/08-notifications.md) ----
# Default channel = Slack incoming webhook. Switch to slack_bot for
# multi-channel routing / threaded replies / @mentions.
NOTIFY_PRIMARY=slack_webhook
SLACK_WEBHOOK_URL=
SLACK_DEFAULT_USERNAME=quant-bot
SLACK_DEFAULT_ICON_EMOJI=:chart_with_upwards_trend:

# Optional: bot-token mode (overrides the webhook primary when set)
# NOTIFY_PRIMARY=slack_bot
# SLACK_BOT_TOKEN=
# SLACK_DEFAULT_CHANNEL=#quant-alerts

# ---- Forward proxy for outbound HTTPS (Slack, akshare, LLMs from CN). ----
# Required when running behind Clash/V2Ray/etc. The watch notifier wires
# these through undici.ProxyAgent (Node's global `fetch` doesn't honor
# them by default).
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1,::1,.local
