# Copy to .env (gitignored). Never commit real keys.

# ---- LLM (see docs/integrations/llm-providers.md) ----
# Provider selection follows the hardcoded catalog order in
# services/py/quant_io/llm/providers.py — first row with an API key
# present in env wins. Set whichever key(s) you want available.
QWEN_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=

# ---- IPC (see docs/integrations/ipc-py-ts.md) ----
# Python Flight server bind port; NestJS dials QUANT_FLIGHT_TARGET=host:port.
QUANT_FLIGHT_PORT=8815
QUANT_FLIGHT_TARGET=127.0.0.1:8815

# ---- API server (NestJS) ----
API_HOST=127.0.0.1
API_PORT=3001
# Extra origins allowed to hit HTTP + Socket.IO (comma list, exact match).
# Loopback hostnames and same-host different-port are auto-allowed; only
# add entries here when serving from a non-loopback hostname.
QUANT_ALLOWED_ORIGINS=

# ---- Logging ----
QUANT_LOG_LEVEL=INFO

# ---- Realtime socket (frontend → API; see docs/modules/12-socket.md) ----
# Defaults: NEXT_PUBLIC_QUANT_SOCKET_URL = http://<window.hostname>:<port>
# Override only when the API runs on a different host than the web app.
NEXT_PUBLIC_QUANT_SOCKET_URL=
NEXT_PUBLIC_QUANT_API_PORT=3001

# ---- Channel module (multi-IM, see docs/modules/11-channel.md) ----
# Comma list of enabled IMs (slack,feishu). Leave blank to disable
# outbound entirely (watch hits will still surface in the FE feed).
CHANNEL_ENABLED=
# Force dry-run mode: log payloads, never call the IM SDK. Useful in dev.
CHANNEL_DRY_RUN=false
# BullMQ persistence (durable retry for outbound). Redis is required
# whenever CHANNEL_ENABLED is non-empty.
CHANNEL_REDIS_URL=redis://127.0.0.1:6379
CHANNEL_BULL_PREFIX=quant:channel

# Slack — Web API for outbound, Socket Mode for inbound (no public ingress).
# Bot token is required when slack ∈ CHANNEL_ENABLED. App token is only
# needed for inbound subscription. Apps managed at https://api.slack.com/apps.
CHANNEL_SLACK_BOT_TOKEN=
CHANNEL_SLACK_APP_TOKEN=
CHANNEL_SLACK_DEFAULT_CHANNEL=#quant-signals

# Feishu (Lark) — Open Platform App Id/Secret + WSClient long-connection.
# Apps managed at https://open.feishu.cn/. Default chat id (oc_...) is the
# fallback target when broadcast() doesn't specify one.
CHANNEL_FEISHU_APP_ID=
CHANNEL_FEISHU_APP_SECRET=
CHANNEL_FEISHU_DEFAULT_CHAT_ID=

# ---- Auth (see docs/integrations/auth.md) ----
# 'disabled' (default): every request inherits a synthetic admin user;
#   data lives at data/users/admin/. Suitable for local LAN deployments.
# 'oauth': require a Feishu OAuth login; per-user data dirs created on
#   first login. Both NestJS (AUTH_MODE) and Next.js
#   (NEXT_PUBLIC_AUTH_MODE) must agree on the value.
AUTH_MODE=disabled
NEXT_PUBLIC_AUTH_MODE=disabled
# Comma-separated list of prefixed IM userIds to promote to the synthetic
# `admin` user (matched verbatim against the inbound sender string built
# by the channel adapter — `${channel}:${externalId}`). Useful when
# AUTH_MODE=oauth but a few IM accounts should still see the admin data
# directory rather than their own per-user dir.
AUTH_ADMIN_USER_IDS=
# HMAC secret used to sign session JWTs. Required when AUTH_MODE=oauth.
# Generate once: `openssl rand -hex 32`. Same secret in apps/web/.env
# AND apps/api/.env so the BFF-minted Bearer verifies on the API side.
NEXTAUTH_SECRET=
# Public origin used to build the OAuth redirect_uri. Must match the
# redirect_uri registered on the Feishu open platform.
NEXTAUTH_URL=http://127.0.0.1:3000
# Feishu OAuth shares CHANNEL_FEISHU_APP_ID / CHANNEL_FEISHU_APP_SECRET
# above. Add `http://127.0.0.1:3000/api/auth/callback/feishu` to the
# app's redirect-URI allow-list and the contact:user.base:readonly scope.

# Override the data root (per-user dirs live under `${QUANT_DATA_ROOT}/users/`).
QUANT_DATA_ROOT=../../data

# ---- Forward proxy for outbound HTTPS (Slack, akshare, LLMs from CN). ----
# Required when running behind Clash/V2Ray/etc. Channel adapters and the
# undici-backed callers wire these through ProxyAgent (Node's global
# `fetch` doesn't honor them by default).
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,.local
