# Copy to .env (gitignored). Never commit real keys.

# ---- LLM (see docs/integrations/llm-providers.md) ----
LLM_PRIMARY_PROVIDER=deepseek
LLM_FALLBACK_PROVIDER=kimi
DEEPSEEK_API_KEY=
KIMI_API_KEY=

# ---- Data sources (see docs/integrations/data-sources.md) ----
TUSHARE_TOKEN=

# ---- Cache backends (see docs/integrations/cache-abstraction.md) ----
CACHE_ROOT=./data
CACHE_KV_BACKEND=file
CACHE_RECORD_BACKEND=parquet
CACHE_TIMESERIES_BACKEND=parquet

# ---- IPC (see docs/integrations/ipc-py-ts.md) ----
QUANT_GRPC_HOST=127.0.0.1
QUANT_GRPC_PORT=8814
QUANT_FLIGHT_PORT=8815

# ---- API server (NestJS) ----
API_HOST=127.0.0.1
API_PORT=3001

# ---- Web (Next.js) ----
NEXT_PUBLIC_API_BASE=http://127.0.0.1:3001

# ---- Logging ----
LOG_LEVEL=info
