# Runtime-only data dirs (audit logs, scratch caches). Underscore-prefixed
# subdirs of data/ are operator-owned, not source.
data/_*/
# Sentiment cache is rebuilt on demand via NewsSentimentService — never source-tracked.
data/sentiment/
# Watch state (W-0): tasks.json is mutable runtime state. universe_{hk,us}.json
# under data/watch IS source-tracked — fresh clones get the lookup tables
# without an akshare round-trip.
apps/api/data/
data/watch/tasks.json

# Test output
coverage/
playwright-report/
test-results/
.logs