# Runtime-only data dirs (audit logs, scratch caches). Underscore-prefixed
# subdirs of data/ are operator-owned, not source.
data/_*/
# Sentiment cache is rebuilt on demand via NewsSentimentService — never source-tracked.
data/sentiment/
# Watch state (W-0): tasks.json is mutable runtime state. universe_{hk,us}.json
# under data/watch IS source-tracked — fresh clones get the lookup tables
# without an akshare round-trip.
apps/api/data/
data/watch/tasks.json
data/watch/groups.json
# Sectors + Sys.Cfg are user state, never source-tracked.
data/sectors/
data/sys-cfg/
data/ta/
# Per-user data dirs (post auth multi-user split). data/users/{uid}/...
# holds personal ledger / watch / sys-cfg / AI cache; data/users/_meta/users.json
# is the user registry. All user state, never source-tracked.
data/users/
# Cron-managed A-share noise filter (BL trigger / 15:15 BJT cron).
# Regenerated on demand; never source-tracked.
data/blacklist.json
# Kline parquet cache: per-code parquet files + the bundled kline.zip
# archive are regenerated locally by ParquetKlineRepo / scripts/pack_kline.py.
# kline.zip is too large for GitHub (>100MB), so the whole dir stays untracked.
data/kline/

# Test output
coverage/
playwright-report/
test-results/
.logs